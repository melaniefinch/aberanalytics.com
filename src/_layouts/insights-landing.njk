---
layout: base.njk
extraCss:
  - /assets/css/insights.css
---

<section class="insights-hero">
    <div class="container">
        <span class="section-label section-label--light reveal">Insights</span>
        <h1 class="section-heading reveal reveal-delay-1" style="color: var(--white);">Analysis, research &amp; perspectives</h1>
        <p class="section-subheading reveal reveal-delay-2" style="color: rgba(255,255,255,0.7);">
            Deep dives into energy market dynamics, modelling methodology, and emerging trends.
        </p>
    </div>
</section>

<section class="insights-listing">
    <div class="container">
        <div class="insights-grid">
            {% for post in collections.insights %}
            <a href="{{ post.url }}" class="insights-card reveal">
                <div class="insights-card__body">
                    <h3 class="insights-card__title">{{ post.data.title }}</h3>
                    <p class="insights-card__excerpt">{{ post.data.excerpt }}</p>
                    <time class="insights-card__date">{{ post.date | readableDate }}</time>
                </div>
            </a>
            {% endfor %}
        </div>

        {% if collections.insights.length == 0 %}
        <div class="insights-empty">
            <p>New insights coming soon.</p>
        </div>
        {% endif %}
    </div>
</section>

<script src="/assets/js/insights-filter.js"></script>

<section class="cta" id="contact">
    <div class="container">
        <div class="cta__inner reveal">
            <h2>Ready to see what's possible?</h2>
            <p>Reach out to set up a demo, or learn more about how our platform can support your team's decisions.</p>
            <div class="cta__bullets">
                <span class="cta__bullet">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Tailored insight for your use case
                </span>
                <span class="cta__bullet">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Flexible engagement levels
                </span>
                <span class="cta__bullet">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Under-the-hood transparency
                </span>
            </div>
            <div class="cta__actions">
                <a href="mailto:info@aberanalytics.com" class="btn btn--primary">
                    Get in Touch
                    <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="mailto:info@aberanalytics.com" class="btn btn--ghost">info@aberanalytics.com</a>
            </div>
        </div>
    </div>
</section>
